---
import BaseLayout from '../layouts/BaseLayout.astro'
import InspirationFilter from '../components/InspirationFilter'
import data from '../../content/inspirations.json'
---

<BaseLayout
  title="Inspirations"
  description="관심 있는 브랜드, 제품, 유용한 링크 큐레이션."
>
  <div class="container page">
    <header class="page-header">
      <h1 class="page-title">Inspirations</h1>
      <p class="page-desc">브랜드, 제품, 링크 아카이브</p>
    </header>

    <InspirationFilter client:load items={data.items} />
  </div>
</BaseLayout>

<style>
  .page {
    padding-top: var(--spacing-2xl);
    padding-bottom: var(--spacing-3xl);
  }

  .page-header {
    margin-bottom: var(--spacing-xl);
  }

  .page-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: var(--spacing-xs);
  }

  .page-desc {
    font-size: 0.9rem;
    color: var(--color-muted);
  }
</style>
