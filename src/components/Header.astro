---
import LanguageSwitcher from './LanguageSwitcher.astro'
import { getLangFromUrl, useTranslations, getLocalePath } from '../i18n/utils'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)

const navLinks = [
  { href: getLocalePath('/gallery', lang), label: t('nav.gallery') },
  { href: getLocalePath('/essay', lang), label: t('nav.essay') },
  { href: getLocalePath('/inspirations', lang), label: t('nav.inspirations') },
]

const pathname = Astro.url.pathname
const homeHref = getLocalePath('/', lang)
---

<header class="header">
  <div class="container header-inner">
    <a href={homeHref} class="logo" aria-label="Home">1lsang</a>
    <nav aria-label="Main navigation">
      <ul class="nav-list">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class:list={['nav-link', { 'nav-link--active': pathname.startsWith(link.href) }]}
            >
              {link.label}
            </a>
          </li>
        ))}
        <li>
          <a
            href="/tech"
            class="nav-link nav-link--tech"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Tech blog (opens in new tab)"
          >
            {t('nav.tech')}
          </a>
        </li>
      </ul>
    </nav>
    <LanguageSwitcher />
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    backdrop-filter: blur(8px);
    background: color-mix(in srgb, var(--color-bg) 90%, transparent);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 3.5rem;
  }

  .logo {
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: -0.03em;
    color: var(--color-fg);
  }

  .logo:hover {
    color: var(--color-fg);
    opacity: 0.7;
  }

  .nav-list {
    display: flex;
    align-items: center;
    gap: var(--spacing-lg);
    list-style: none;
  }

  .nav-link {
    font-size: 0.875rem;
    color: var(--color-muted);
    transition: color var(--transition);
  }

  .nav-link:hover,
  .nav-link--active {
    color: var(--color-fg);
  }

  .nav-link--tech {
    color: var(--color-accent);
    opacity: 0.8;
  }

  .nav-link--tech:hover {
    opacity: 1;
    color: var(--color-accent);
  }

  @media (max-width: 640px) {
    .nav-list {
      gap: var(--spacing-md);
    }

    .nav-link {
      font-size: 0.8125rem;
    }
  }
</style>
